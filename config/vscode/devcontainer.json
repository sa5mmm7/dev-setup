{
  "name": "Python Dev Container (Podman)",
  "build": {
    "dockerfile": "__DOCKERFILE_PATH__"
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true
        },
        "remote.autoForwardPorts": false
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter",
        "redhat.vscode-yaml",
        "googlecloudtools.cloudcode",
        "ashishalex.dataform-lsp-vscode"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.config/gcloud/application_default_credentials.json,target=/gcp/adc.json,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly"
  ],
  "remoteEnv": {
    "GOOGLE_APPLICATION_CREDENTIALS": "/gcp/adc.json",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "postCreateCommand": "pip install -r requirements.txt 2>/dev/null || true",
  "runArgs": ["--privileged"]
}
