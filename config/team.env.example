# Team configuration — copy this file to config/team.env and fill in your values.
# config/team.env is gitignored and must be created locally before running onboarding.
#
#   cp config/team.env.example config/team.env
#   # then edit config/team.env with your team's values

# --- GCP ---
GCP_PROJECT="your-gcp-project-id"
GCP_REGION="us-central1"
GCP_ZONE="us-central1-f"
ARTIFACT_REGISTRY="REGION-docker.pkg.dev"
ARTIFACT_REGISTRY_PROJECT="your-artifact-registry-project"

# --- Team identity ---
# Used in prompts (e.g. "log in with your <TEAM_NAME> Google account")
TEAM_NAME="Your Team Name"

# --- Podman VM resources ---
# Recommended: half of the machine's CPUs and RAM.
PODMAN_CPUS=4
PODMAN_MEMORY_MB=8192

# --- Python ---
# Space-separated full versions (major.minor.patch) to install via pyenv.
# The order determines the menu order in project-devcontainer.sh.
PYTHON_VERSIONS=("3.10.14" "3.14.0")

# --- Bootstrap ---
# Full HTTPS URL to this repo — used by bootstrap.sh to clone on a fresh machine.
ONBOARDING_REPO_URL="https://github.com/YOUR_ORG/dev-setup.git"
